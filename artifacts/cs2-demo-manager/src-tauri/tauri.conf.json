{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "FACEIT easyDemo CS2",
  "version": "0.2.0",
  "identifier": "com.easydemocs2.app",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "beforeDevCommand": "pnpm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "FACEIT easyDemo CS2",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://api.lemonsqueezy.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: tauri: asset:; connect-src 'self' https://api.lemonsqueezy.com https: ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
